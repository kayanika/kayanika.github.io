<article class="research" data-page="research">

    <header>
      <h2 class="h2 article-title">Research</h2>
    </header>

    <section class="timeline">
      <ol class="timeline-list">

        <% researches.forEach(function(research){ %>
          <li class="timeline-item">
            <h4 class="h4 timeline-item-title"><%=research.title%></h4>
            <h5 class="h5 timeline-item-subtitle-research"><%=research.subtitle%></h5>

            <% /* Supervisor(s) */ %>
            <% if(research.supervisor && research.supervisor.length > 0) { %>
              <h5 class="h5 timeline-item-subtitle-research">Supervisor: 
                <% research.supervisor.forEach(function(sup, index){ %>
                  <%= sup %><% if(index < research.supervisor.length - 1) { %>, <% } %>
                <% }); %>
              </h5>
            <% } %>

            <% /* Co-authors */ %>
            <% if(research.coauthors && research.coauthors.length > 0 ) { %>
                <h5 class="h5 timeline-item-subtitle-research">Co-authors: 
                    <% research.coauthors.forEach(function(coauthor, index){ %>
                        <%= coauthor %>
                        <% if(index < research.coauthors.length - 1) { %> , <% } %>
                    <% }); %>
                </h5>
            <% } %>

            <% if(research.keywords && research.keywords.length > 0 ) { %>
                <h5 class="h5 timeline-item-subtitle-research">Keywords: 
                    <% research.keywords.forEach(function(keyword, index){ %>
                        <%= keyword %>
                        <% if(index < research.keywords.length - 1) { %> , <% } %>
                    <% }); %>
                </h5>
            <% } %>

            <% /* Publication metadata */ %>
            <% if(research.published) { %>
              <h5 class="h5 timeline-item-subtitle-research">
                Published in: <%= research.venue || '' %> <%= research.year ? ('(' + research.year + ')') : '' %>
                <% if(research.link) { %>
                  — <a href="<%=research.link%>" target="_blank" rel="noopener noreferrer">paper</a>
                <% } %>
              </h5>
            <% } %>

            <br>
            <p class="timeline-text-bulletpoint">
              <%=research.description%>
            </p>
          </li>
        <% }); %>

      </ol>

    </section>
  </article>